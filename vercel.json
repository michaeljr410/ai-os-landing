{
  "cleanUrls": true,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 15
    },
    "api/cron/drip.js": {
      "maxDuration": 30
    },
    "api/cron/sales-digest.js": {
      "maxDuration": 30
    },
    "api/estimate.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/drip",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/sales-digest",
      "schedule": "0 23 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ]
}
